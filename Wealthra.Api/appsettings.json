{
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=WealthraDb;Username=postgres;Password=YOUR_PASSWORD"
  },
  "JwtSettings": {
    "Secret": "THIS_IS_A_SUPER_SECRET_KEY_FOR_JWT_TOKEN_GENERATION_AT_LEAST_32_CHARS",
    "ExpiryMinutes": "60",
    "Issuer": "WealthraApi",
    "Audience": "WealthraClient"
  },
  "ExtractionServices": {
    "OcrBaseUrl": "http://ocr:8000/",
    "SttBaseUrl": "http://stt:8000/",
    "CopilotBaseUrl": "http://copilot:8000/",
    "TimeoutSeconds": 60
  },
  "Groq": {
    "Model": "meta-llama/llama-4-scout-17b-16e-instruct",
    "TimeoutSeconds": 120
  },
  "Recommendations": {
    "EnableCollaborativeFiltering": true,
    "EnableSemanticTips": true
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "UseSsl": false,
    "Username": "your-gmail@gmail.com",
    "Password": "your-gmail-app-password",
    "FromEmail": "your-gmail@gmail.com",
    "FromName": "Wealthra"
  }
}