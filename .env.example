# Copy to `.env` next to docker-compose.yaml (the real `.env` is gitignored).
# Compose loads `.env` automatically for variable substitution when you run: docker compose up

# GitHub Actions deploy (.github/workflows/deploy.yml) writes this file on the server from
# repository secrets — add these under Settings → Secrets and variables → Actions:
#   POSTGRES_PASSWORD, JWT_SETTINGS_SECRET, GROQ_API_KEY
# Optional SMTP (same names as below; omit any you do not use):
#   SMTP_HOST, SMTP_PORT, SMTP_USE_SSL, SMTP_TLS, SMTP_USERNAME, SMTP_PASSWORD, SMTP_FROM_EMAIL, SMTP_FROM_NAME
# (plus SERVER_IP and SSH_PRIVATE_KEY for the SSH steps)
# Production docker-compose.yaml (server) expects **registry images only** (no ../wealthra-ocr on the host):
#   WEALTHRA_API_IMAGE, WEALTHRA_OCR_IMAGE, WEALTHRA_STT_IMAGE
# CI sets these from ghcr.io/wealthra/… — change org/name in .github/workflows/deploy.yml if needed.
# For laptop development use docker-compose.local.yaml (builds from ../wealthra-ocr and ../wealthra-stt).

# Database (must match across db service and API connection string)
POSTGRES_USER=wealthra_user
POSTGRES_PASSWORD=
POSTGRES_DB=wealthra_db

# ASP.NET JWT signing key — at least 32 characters
JWT_SETTINGS_SECRET=

# Groq API key — used by ocr, stt, and API expense enrichment (same key is fine)
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# Demo model lineup (override defaults from compose/services if needed)
COPILOT_MODEL_FAST=qwen/qwen3-32b
COPILOT_MODEL_REASONING=groq/compound
STT_AUDIO_MODEL=whisper-large-v3-turbo
STT_LLM_MODEL=openai/gpt-oss-120b
OCR_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# WEALTHRA_API_IMAGE=ghcr.io/wealthra/wealthra-api:latest
# WEALTHRA_OCR_IMAGE=ghcr.io/wealthra/wealthra-ocr:latest
# WEALTHRA_STT_IMAGE=ghcr.io/wealthra/wealthra-stt:latest

# --- SMTP (optional; password reset and other IEmailSender flows) ---
# docker-compose substitutes these into api.environment (ASP.NET Smtp section). Use the same Smtp__* names here.
#
# Do not wrap the Gmail app password in quotes — use the 16 characters with or without spaces:
#   Smtp__Password=abcdabcdabcdabcd
#
#   Smtp__Host=smtp.gmail.com
#   Smtp__Port=587
#   Smtp__UseSsl=false
#   Smtp__Tls=StartTls
#   Smtp__Username=youraddress@gmail.com
#   Smtp__Password=
#   Smtp__FromEmail=youraddress@gmail.com
#   Smtp__FromName=Wealthra
#
# Tls (optional): None | StartTls | Ssl | Auto. Leave empty to derive from UseSsl.
