# Copy to `.env` next to docker-compose.yaml (the real `.env` is gitignored).
# Compose loads `.env` automatically for variable substitution when you run: docker compose up

# GitHub Actions deploy (.github/workflows/deploy.yml) writes this file on the server from
# repository secrets — add these under Settings → Secrets and variables → Actions:
#   POSTGRES_PASSWORD, JWT_SETTINGS_SECRET, GROQ_API_KEY
# (plus SERVER_IP and SSH_PRIVATE_KEY for the SSH steps)
# Optional: set API_IMAGE in the workflow if your GHCR path is not ghcr.io/wealthra/wealthra-api:latest

# Database (must match across db service and API connection string)
POSTGRES_USER=wealthra_user
POSTGRES_PASSWORD=
POSTGRES_DB=wealthra_db

# ASP.NET JWT signing key — at least 32 characters
JWT_SETTINGS_SECRET=

# Groq API key — used by ocr, stt, and API expense enrichment (same key is fine)
GROQ_API_KEY=

# API container image — CI sets this on the server; for local `docker compose build` leave unset (compose default)
# WEALTHRA_API_IMAGE=ghcr.io/wealthra/wealthra-api:latest
